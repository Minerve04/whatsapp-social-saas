# --- Serveur ---
PORT=8080

# --- Base de donnees ---
DATABASE_URL=postgres://saas:saas@localhost:5432/saas

# --- WhatsApp Business Platform (via BSP, ex. 360dialog) ---
# La seule ligne "pro/API" du systeme : TON numero, pas celui du client.
WHATSAPP_BSP_BASE_URL=https://waba-v2.360dialog.io
WHATSAPP_API_KEY=REMPLACER_par_la_cle_du_BSP
# Jeton arbitraire que tu choisis pour verifier l'authenticite des webhooks entrants.
WHATSAPP_WEBHOOK_VERIFY_TOKEN=REMPLACER_par_un_secret_aleatoire

# --- LLM (redaction des legendes) ---
LLM_API_KEY=REMPLACER_par_la_cle_LLM
LLM_MODEL=claude-sonnet-4-5
LLM_API_URL=https://api.anthropic.com/v1/messages

# --- Metricool ---
# Un seul token couvre toutes les brands (blogId). Plan Advanced requis.
METRICOOL_BASE_URL=https://app.metricool.com/api
METRICOOL_USER_TOKEN=REMPLACER_par_le_token_Metricool
METRICOOL_USER_ID=REMPLACER_par_l_id_utilisateur_Metricool
